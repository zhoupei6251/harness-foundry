{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness Foundry Health Metrics",
  "description": "健康检查指标的 JSON Schema 定义",
  "type": "object",
  "required": ["timestamp", "system_health"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "system_health": {
      "type": "object",
      "required": ["status", "checks"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["healthy", "degraded", "unhealthy"]
        },
        "checks": {
          "type": "object",
          "properties": {
            "config_validity": { "$ref": "#/$defs/healthCheck" },
            "reference_integrity": { "$ref": "#/$defs/healthCheck" },
            "execution_context": { "$ref": "#/$defs/healthCheck" },
            "guardrail_config": { "$ref": "#/$defs/healthCheck" },
            "instinct_quality": { "$ref": "#/$defs/healthCheck" },
            "skill_coverage": { "$ref": "#/$defs/healthCheck" },
            "agent_format_consistency": { "$ref": "#/$defs/healthCheck" }
          }
        }
      }
    },
    "token_estimates": {
      "type": "object",
      "properties": {
        "core_rules_total_lines": { "type": "integer" },
        "entry_overhead_lines": { "type": "integer" }
      }
    }
  },
  "$defs": {
    "healthCheck": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "warn", "fail", "info"]
        },
        "message": { "type": "string" },
        "details": { "type": "array" }
      }
    }
  }
}

{
  "version": "1.0",
  "description": "Harness Foundry Guardrail 配置中心 — 参考 OpenAI Agents SDK 2026 双层 Guardrail 架构",
  "guardrails": {
    "input": {
      "parallel": true,
      "fail_strategy": "any",
      "description": "Input Guardrail 并行执行，任一规则触发即拦截",
      "rules": [
        {
          "id": "prompt-injection-canary",
          "type": "canary_token",
          "priority": 1,
          "action": "block",
          "mode": "warn",
          "description": "检测 prompt 注入尝试（Canary Token 被泄露）",
          "doc": "hooks/guardrails/rules/prompt-injection.md",
          "enabled": true
        },
        {
          "id": "sqli-pattern",
          "type": "pattern_match",
          "priority": 2,
          "action": "block",
          "mode": "warn",
          "description": "检测 SQL 注入尝试",
          "patterns": [
            "DROP TABLE",
            "DROP DATABASE",
            "UNION SELECT",
            "OR 1=1",
            "' OR '1'='1",
            "--\\s*$",
            "xp_cmdshell",
            "INFORMATION_SCHEMA"
          ],
          "enabled": true
        },
        {
          "id": "command-injection",
          "type": "pattern_match",
          "priority": 2,
          "action": "block",
          "mode": "warn",
          "description": "检测命令注入尝试",
          "patterns": [
            "; rm -rf",
            "$(curl",
            "$(wget",
            "`rm ",
            "`wget",
            "| /bin/bash",
            "| /bin/sh",
            "eval\\s+",
            "__import__\\s*\\(\\s*['\"]os['\"]",
            "os\\.system\\s*\\("
          ],
          "enabled": true
        },
        {
          "id": "prompt-override",
          "type": "pattern_match",
          "priority": 3,
          "action": "block",
          "mode": "warn",
          "description": "检测 prompt 覆盖/角色劫持尝试",
          "patterns": [
            "ignore (all )?(previous|above) (instructions|rules|constraints)",
            "you are now",
            "your new (role|identity|name) is",
            "forget (everything|all rules)",
            "disregard (your )?(system )?prompt",
            "you are (no longer|not) an AI",
            "pretend (you are|to be)",
            "act as if"
          ],
          "enabled": true
        },
        {
          "id": "path-traversal",
          "type": "pattern_match",
          "priority": 3,
          "action": "block",
          "mode": "warn",
          "description": "检测路径遍历/文件读取攻击",
          "patterns": [
            "\\.\\.\\/\\.\\.\\/",
            "\\/etc\\/passwd",
            "\\/etc\\/shadow",
            "C:\\\\Windows\\\\System32",
            "\\/proc\\/self\\/",
            "\\/var\\/log\\/",
            "\\.env",
            "id_rsa",
            "id_ed25519"
          ],
          "enabled": true
        }
      ]
    },
    "output": {
      "sequential": true,
      "fail_strategy": "block",
      "description": "Output Guardrail 顺序执行，任何一条 block 则阻止输出",
      "rules": [
        {
          "id": "secret-leak-output",
          "type": "sensitive_data",
          "priority": 1,
          "action": "block",
          "description": "阻止输出包含 API Key / Token / 密码",
          "patterns": [
            "sk-[a-zA-Z0-9]{32,}",
            "api[_-]?key['\"]?\\s*[:=]\\s*['\"][a-zA-Z0-9_\\-]{20,}['\"]",
            "password['\"]?\\s*[:=]\\s*['\"][^'\"]+['\"]",
            "secret['\"]?\\s*[:=]\\s*['\"][^'\"]+['\"]",
            "token['\"]?\\s*[:=]\\s*['\"][a-zA-Z0-9_\\-]{20,}['\"]",
            "BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY",
            "ghp_[a-zA-Z0-9]{36}",
            "gho_[a-zA-Z0-9]{36}",
            "ghu_[a-zA-Z0-9]{36}"
          ],
          "enabled": true
        },
        {
          "id": "canary-token-leak",
          "type": "canary_detect",
          "priority": 1,
          "action": "block",
          "description": "检测 Agent 输出中是否泄露 Canary Token（Prompt 泄露检测）",
          "doc": "hooks/guardrails/rules/canary-check.md",
          "enabled": true
        },
        {
          "id": "never-violation",
          "type": "rule_check",
          "priority": 2,
          "action": "block",
          "mode": "warn",
          "description": "检查输出是否违反 NEVER.md 规则",
          "reference": "core/NEVER.md",
          "checks": [
            "shell 写文本文件",
            "静默吞错误不报告",
            "AOP 自调用",
            "循环 SQL 查询",
            "未声明 Route 即执行",
            "AI 味写作",
            "自动 push",
            "自动 commit"
          ],
          "enabled": true
        },
        {
          "id": "ai-writing-markers",
          "type": "pattern_match",
          "priority": 3,
          "action": "warn",
          "description": "检测 AI 写作痕迹（novel/news 域）",
          "patterns": [
            "总而言之",
            "值得注意的是",
            "在这个充满",
            "不仅仅是.*更是",
            "从某种程度上说",
            "毋庸置疑",
            "不可否认",
            "深深地",
            "极大地",
            "充分体现了"
          ],
          "enabled": true,
          "domains": ["novel", "news"]
        },
        {
          "id": "syntax-check",
          "type": "static_analysis",
          "priority": 4,
          "action": "warn",
          "description": "代码语法检查（code 域）",
          "file_patterns": ["*.java", "*.py", "*.go", "*.ts", "*.tsx", "*.vue", "*.rs"],
          "enabled": true,
          "domains": ["code"]
        }
      ]
    }
  },
  "audit": {
    "enabled": true,
    "log_path": ".ai-runtime-artifacts/guardrail-audit.jsonl",
    "retention_days": 90,
    "schema": "hooks/guardrails/audit-log-schema.json"
  },
  "_canary_note": "P2-8: Canary Token 检测规则见 hooks/guardrails/rules/canary-check.md，Token 定义见 core/security/canary-tokens.yaml（不纳入版本控制）"
}

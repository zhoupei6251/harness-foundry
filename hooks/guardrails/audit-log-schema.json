{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Guardrail Audit Log Entry",
  "description": "Guardrail 审计日志单条记录结构",
  "type": "object",
  "required": ["id", "timestamp", "guardrail_type", "rule_id", "result"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "审计条目唯一 ID"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 时间戳"
    },
    "guardrail_type": {
      "type": "string",
      "enum": ["input", "output"],
      "description": "Guardrail 类型"
    },
    "rule_id": {
      "type": "string",
      "description": "触发的规则 ID"
    },
    "result": {
      "type": "string",
      "enum": ["pass", "warn", "block"],
      "description": "检查结果"
    },
    "action_taken": {
      "type": "string",
      "enum": ["allow", "warn_user", "block_execution", "request_confirmation"],
      "description": "实际采取的动作"
    },
    "context": {
      "type": "object",
      "properties": {
        "session_id": {
          "type": "string",
          "description": "会话 ID"
        },
        "domain": {
          "type": "string",
          "enum": ["code", "novel", "news", "shared"],
          "description": "当前域"
        },
        "tool": {
          "type": "string",
          "description": "触发检查的工具名称"
        },
        "agent_role": {
          "type": "string",
          "description": "当前 Agent 角色"
        }
      }
    },
    "detail": {
      "type": "object",
      "properties": {
        "matched_pattern": {
          "type": "string",
          "description": "匹配到的具体模式（脱敏后）"
        },
        "matched_location": {
          "type": "string",
          "description": "匹配位置（prompt 开头/中部/结尾，或行号）"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "严重程度"
        },
        "user_notified": {
          "type": "boolean",
          "description": "是否已通知用户"
        },
        "override_bypass": {
          "type": "boolean",
          "description": "用户是否使用了 --skip-guardrail 绕过"
        }
      }
    }
  }
}
